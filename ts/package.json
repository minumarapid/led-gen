{
  "name": "led-gen",
  "version": "0.1.0",
  "description": "A high-performance library that includes WASM code to convert images into an LED-style appearance.",
  "author": "minumarapid",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "postbuild": "shx cp ../src/wasm/pkg/*.wasm dist/"
  },
  "devDependencies": {
    "shx": "^0.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
