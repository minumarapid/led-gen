{
  "name": "led-gen",
  "version": "0.3.0",
  "description": "A high-performance library that includes WASM code to convert images into an LED-style appearance.",
  "author": "minumarapid <contact@o38.me>",
  "license": "BSD-2-Clause",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "image-processing",
    "wasm",
    "webassembly",
    "led",
    "canvas",
    "rust"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minumarapid/led-gen.git"
  },
  "bugs": {
    "url": "https://github.com/minumarapid/led-gen/issues"
  },
  "homepage": "https://github.com/minumarapid/led-gen#readme",
  "scripts": {
    "prebuild": "wasm-pack build ../../crates/led-gen-wasm --target web",
    "build": "tsup",
    "postbuild": "shx cp ../../crates/led-gen-wasm/pkg/*.wasm dist/",

    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "shx": "^0.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
